# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# DBA ingestion source PDFs (publicly available at colombiaaprende.edu.co)
/data/dba-source/

# Playwright runtime artifacts
/test-results/
/playwright-report/

# Supabase CLI local state (runs in Docker)
/supabase/.branches/
/supabase/.temp/

# Prompt eval harness generated outputs (re-generated per prompt_version)
/scripts/pbl/fixtures/*.output.json
/scripts/pbl/fixtures/*.output.md
/scripts/pbl/fixtures/*.rating.yaml
